{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CardCollection",
  "type": "object",
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["player_id", "card_id", "quantity", "first_acquired_at"],
        "properties": {
          "player_id":         { "type": "string" },
          "card_id":           { "type": "string" },
          "quantity":          { "type": "integer", "minimum": 1 },
          "first_acquired_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
